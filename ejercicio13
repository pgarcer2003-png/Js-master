const names = [
  "Peter",
  "Steve",
  "Tony",
  "Natasha",
  "Clint",
  "Logan",
  "Xabier",
  "Bruce",
  "Peggy",
  "Jessica",
  "Marc"
];

function nameFinder(nameList, name) {
  const position = nameList.indexOf(name);

  if (position !== -1) {
    return {
      exists: true,
      position: position
    };
  }

  return false;
}

console.log(nameFinder(names, "Tony"));
console.log(nameFinder(names, "Thor"));